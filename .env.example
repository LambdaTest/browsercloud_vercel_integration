# ---- auth-plus (TestMu AI / Browsercloud) OAuth — Flow B ----
# Which auth-plus environment to target: stage | prod
AUTHPLUS_ENV=stage

# OAuth client credentials from `POST /oauth2/register` (see scripts/register_client.py)
AUTHPLUS_CLIENT_ID=
AUTHPLUS_CLIENT_SECRET=
# Our hosted HTTPS callback — must EXACTLY match the registered redirect_uri (OAuth 2.1 exact match)
AUTHPLUS_REDIRECT_URI=http://127.0.0.1:8000/api/auth/callback
AUTHPLUS_SCOPE=*

# How to retrieve username + access_key after consent: introspect | userinfo
# NOTE: access_key is NOT in the planned JWT claims, so `introspect` is the source of truth today.
CREDENTIAL_METHOD=introspect
# Pre-built Api-Secret = base64( RSA-OAEP( security_salt, server_public_key ) )
# Build it with scripts/build_api_secret.py once the Force team provisions your service row.
AUTHPLUS_INTROSPECT_API_SECRET=

# ---- Vercel integration OAuth — Flow A ----
# From the Vercel Integration Console (https://vercel.com/dashboard/integrations/console)
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/vercel/callback

# ---- Injected env var names in the user's Vercel project ----
INJECT_USERNAME_KEY=LT_USERNAME
INJECT_ACCESS_KEY_KEY=LT_ACCESS_KEY

# ---- Cookie/state signing ----
SESSION_SECRET=change-me-to-a-long-random-string
