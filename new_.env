# ---- auth-plus (TestMu AI / Browsercloud) OAuth — Flow B ----
AUTHPLUS_ENV=stage

# Registered web/confidential client (stage) — from scripts/register_client.py
# Local testing uses a native/public client (loopback + PKCE, no secret).
# The deployed integration will use the web/confidential client instead.
AUTHPLUS_CLIENT_ID=trsM5TNXL-7Rbygd_fm2nQ
AUTHPLUS_CLIENT_SECRET=QtlkAA1wvZ0e-mhiwxrvgRCBFu5PRqnZhyxobGiiYBw
AUTHPLUS_REDIRECT_URI=https://browsercloud-vercel-integration.vercel.app/api/auth/callback
AUTHPLUS_SCOPE=*

# How to retrieve username + access_key: introspect | userinfo
CREDENTIAL_METHOD=introspect
# Pending: build with scripts/build_api_secret.py once the Force team provisions our service row.
AUTHPLUS_INTROSPECT_API_

# ---- Vercel integration OAuth — Flow A ----
# Pending: create the integration in the Vercel Integration Console.
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=https://browsercloud-vercel-integration.vercel.app/api/integrations/vercel/callback

# ---- Injected env var names in the user's Vercel project ----
INJECT_USERNAME_KEY=LT_USERNAME
INJECT_ACCESS_KEY_KEY=LT_ACCESS_KEY

# ---- Cookie/state signing ----
SESSION_SECRET=-cIMdXVE4RuQsf44taE8OCynFALtn_65xCteBJBSAFmDLHSxx5zm4cKmTdMIwC6f
